# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openclaw

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars

# OAuth (optional - leave empty to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (optional - for transactional emails)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Signal integrations — token encryption (required if using any OAuth integration)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Gmail / Google Calendar integration
# Uses the same GOOGLE_CLIENT_ID/SECRET above (ensure gmail.readonly + calendar.readonly scopes)
# Google Cloud Pub/Sub topic for Gmail push notifications
GOOGLE_PUBSUB_TOPIC=projects/YOUR_PROJECT/topics/gmail-push

# Microsoft / Outlook integration
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# LinkedIn enrichment via Proxycurl
PROXYCURL_API_KEY=

# Zoom Server-to-Server OAuth
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_WEBHOOK_SECRET_TOKEN=

# AssemblyAI call transcription
ASSEMBLYAI_API_KEY=

# AI chat (OpenRouter)
OPENROUTER_API_KEY=

# Cron job authorization
# Generate: openssl rand -hex 32
CRON_SECRET=

# Docker Compose production (optional - used by docker-compose.prod.yml)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=openclaw
# APP_PORT=3000
